# ============================================================
# .env.example
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is NEVER committed to git (it's in .gitignore).
#
# How to use:
#   cp .env.example .env
#   (then edit .env with your actual values)
# ============================================================

# Server settings
HOST=0.0.0.0
PORT=8000

# Frontend URL(s) allowed to call this API
# Separate multiple URLs with commas
# Development:
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production (replace with your actual Vercel URL):
# ALLOWED_ORIGINS=https://your-app.vercel.app

# How long (seconds) to keep downloaded files before deleting them
# 300 = 5 minutes
FILE_TTL_SECONDS=300

# Maximum file size in MB
MAX_FILE_SIZE_MB=500
